# ===== Supabase (required) =====
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
JOBPILOT_USER_ID=00000000-0000-0000-0000-000000000000

# ===== Apify (LinkedIn / Indeed / Glassdoor scrapers) =====
APIFY_TOKEN=apify_api_...

# ===== AI =====
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

DEEPSEEK_API_KEY=sk-...
DEEPSEEK_REASONER_MODEL=deepseek-reasoner
DEEPSEEK_CHAT_MODEL=deepseek-chat

# ===== Captcha (pick one) =====
CAPTCHA_PROVIDER=2captcha          # 2captcha | capsolver | anticaptcha
CAPTCHA_API_KEY=...

# ===== Residential proxies =====
PROXY_HOST=geo.iproyal.com
PROXY_PORT=12321
PROXY_USER=...
PROXY_PASS=...
PROXY_COUNTRY=US

# ===== Gmail OAuth (reading OTP/verification emails) =====
GMAIL_OAUTH_CLIENT_ID=...apps.googleusercontent.com
GMAIL_OAUTH_CLIENT_SECRET=...
GMAIL_OAUTH_REFRESH_TOKEN=1//0...
GMAIL_EMAIL=you@gmail.com

# ===== Apply credentials =====
APPLY_EMAIL=you+apply@gmail.com
APPLY_PASSWORD=use-a-strong-password
APPLY_DEFAULT_PHONE=+15551234567

# ===== Optional =====
ALERT_WEBHOOK_URL=
LOG_LEVEL=INFO
WORKER_VERSION=0.1.0

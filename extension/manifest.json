{
  "manifest_version": 3,
  "name": "JobPilot Capture",
  "version": "1.1.0",
  "description": "Capture jobs, queue applications, and (optionally) sync your logged-in session to JobPilot's VPS worker so auto-apply skips the login wall.",
  "permissions": ["storage", "activeTab", "alarms"],
  "host_permissions": [
    "https://*.linkedin.com/*",
    "https://*.indeed.com/*",
    "https://*.glassdoor.com/*",
    "https://*.ziprecruiter.com/*",
    "https://wellfound.com/*",
    "https://*.wellfound.com/*",
    "https://*.dice.com/*"
  ],
  "background": { "service_worker": "background.js", "type": "module" },
  "action": { "default_popup": "popup.html", "default_icon": "icon.png" },
  "options_page": "options.html",
  "icons": { "48": "icon.png", "128": "icon.png" },
  "content_scripts": [
    { "matches": ["https://*.linkedin.com/jobs/*"], "js": ["content-linkedin.js"], "run_at": "document_idle" },
    { "matches": ["https://*.indeed.com/*"], "js": ["content-indeed.js"], "run_at": "document_idle" },
    { "matches": ["https://*.glassdoor.com/*"], "js": ["content-glassdoor.js"], "run_at": "document_idle" },
    { "matches": ["https://*.ziprecruiter.com/*"], "js": ["content-ziprecruiter.js"], "run_at": "document_idle" },
    { "matches": ["https://wellfound.com/*", "https://*.wellfound.com/*"], "js": ["content-wellfound.js"], "run_at": "document_idle" },
    { "matches": ["https://*.dice.com/*"], "js": ["content-dice.js"], "run_at": "document_idle" },
    {
      "matches": [
        "https://*.linkedin.com/jobs/*",
        "https://*.indeed.com/viewjob*",
        "https://*.indeed.com/jobs*",
        "https://*.glassdoor.com/job-listing/*",
        "https://*.ziprecruiter.com/jobs/*",
        "https://wellfound.com/jobs/*",
        "https://wellfound.com/company/*/jobs/*",
        "https://*.dice.com/job-detail/*"
      ],
      "js": ["content-apply.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://*.linkedin.com/*",
        "https://*.indeed.com/*",
        "https://*.glassdoor.com/*",
        "https://*.ziprecruiter.com/*",
        "https://wellfound.com/*",
        "https://*.wellfound.com/*",
        "https://*.dice.com/*"
      ],
      "js": ["content-cookies.js"],
      "run_at": "document_idle"
    }
  ]
}
